generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model User {
  user_id        String @id
  name           String
  email          String
  phone          String
  loyalty_points Int
  role           String

  flight_tickets FlightTicket[]
  hotel_bookings HotelBooking[]
  food_orders    FoodOrder[]
  reviews        Review[]
  notifications  Notification[]
  chats          Chat[]
}

model Flight {
  flight_id      String         @id
  airline        String
  origin         String
  destination    String
  departure_time DateTime
  price          Float
  tickets        FlightTicket[]
}

model FlightTicket {
  ticket_id String @id
  user_id   String
  flight_id String
  seat      String
  status    String

  user   User   @relation(fields: [user_id], references: [user_id])
  flight Flight @relation(fields: [flight_id], references: [flight_id])
}

model Hotel {
  hotel_id        String         @id
  name            String
  location        String
  rating          Float
  price_per_night Float
  amenities       String[]
  bookings        HotelBooking[]
}

model HotelBooking {
  booking_id  String   @id
  user_id     String
  hotel_id    String
  check_in    DateTime
  check_out   DateTime
  guests      Int
  total_price Float
  status      String

  user  User  @relation(fields: [user_id], references: [user_id])
  hotel Hotel @relation(fields: [hotel_id], references: [hotel_id])
}

model Restaurant {
  res_id            String      @id
  name              String
  cuisine           String
  rating            Float
  delivery_time_min Int
  orders            FoodOrder[]
}

model FoodOrder {
  order_id      String   @id
  user_id       String
  restaurant_id String
  menu_items    String[]
  total_price   Float
  status        String
  rider_name    String?

  user       User       @relation(fields: [user_id], references: [user_id])
  restaurant Restaurant @relation(fields: [restaurant_id], references: [res_id])
}

model Location {
  location_id     String @id
  name            String
  type            String
  ref_id          String
  address         String
  coordinates     Json
  operating_hours String
}

model Review {
  review_id   String   @id
  user_id     String
  target_id   String
  target_type String
  rating      Float
  comment     String
  timestamp   DateTime
  images      String[]

  user User @relation(fields: [user_id], references: [user_id])
}

model Notification {
  notif_id    String   @id
  user_id     String
  type        String
  title       String
  message     String
  is_read     Boolean
  timestamp   DateTime
  action_link String

  user User @relation(fields: [user_id], references: [user_id])
}

model Chat {
  chat_id  String @id
  user_id  String
  shop_id  String
  status   String
  messages Json

  user User @relation(fields: [user_id], references: [user_id])
}
